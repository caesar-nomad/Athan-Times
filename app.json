  "changelog": {
    "1.4.29": {
      "en": "Add global Flow tokens for prayer times (athan_fajr, athan_dhuhr, athan_asr, athan_maghrib, athan_isha, athan_suhoor, month_is_ramadan) — readable by any app or flow"
    },
    "1.4.30": {
      "en": "Fix Prayer Schedule device pairing — now appears in Add Device"
    },
    "1.4.31": {
      "en": "Fix Prayer Schedule device not appearing in pairing list"
    },
    "1.4.32": {
      "en": "Fix Prayer Schedule device pairing via Homey Compose driver manifest"
    },
    "1.4.33": {
      "en": "Fix Prayer Schedule device pairing — driver.compose.json in correct location"
    },
    "2.0.0": {
      "en": "Major update: Added Prayer Schedule virtual device exposing all prayer times as capabilities (readable by other apps like Gemini). Added global Flow tokens for all prayer times. Added Web API endpoint for external integrations. Added Arabic localization. Added retry logic for daily sync. Fixed flow cards after Homey Compose migration."
    },
    "2.1.0": {
      "en": "Suhoor time is now always shown and triggered regardless of Ramadan — use the 'Is Ramadan' Flow token to act on it conditionally. Removed virtual Prayer Schedule device. Renamed Flow token to month_is_ramadan."
    },
    "2.1.2": {
      "en": "Fixed memory leaks: settings listener and retry timeouts now properly cleaned up on app restart."
    },
    "2.2.0": {
      "en": "Added translations for Dutch, German, French, Italian, Swedish, Norwegian, Spanish, Danish, Russian, Polish and Korean — covering the app description, Flow cards and prayer names."
    }
  },
