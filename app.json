{
  "id": "com.riyadh.athan",
  "sdk": 3,
  "name": {
    "en": "Athan Times",
    "ar": "أوقات الأذان"
  },
  "description": {
    "en": "Never miss a prayer, wherever you are.",
    "ar": "لا تفوت صلاتك"
  },
  "version": "1.4.31",
  "compatibility": ">=5.0.0",
  "category": "tools",
  "tags": {
    "en": [
      "islam",
      "prayer",
      "ramadan",
      "athan"
    ]
  },
  "brandColor": "#064e3b",
  "author": {
    "name": "Caesar"
  },
  "contributors": {
    "developers": [
      {
        "name": "Caesar"
      }
    ]
  },
  "homepage": "https://github.com/caesar-nomad/Athan-Times",
  "source": "https://github.com/caesar-nomad/Athan-Times",
  "bugs": {
    "url": "https://github.com/caesar-nomad/Athan-Times/issues"
  },
  "support": "mailto:cords_esquire2i@icloud.com",
  "images": {
    "large": "/assets/large.jpeg",
    "small": "/assets/small.jpeg"
  },
  "api": {
    "getPrayerTimes": {
      "method": "GET",
      "path": "/prayer-times",
      "public": false
    }
  },
  "permissions": [
    "homey:manager:geolocation"
  ],
  "changelog": {
    "1.4.29": {
      "en": "Add global Flow tokens for prayer times (athan_fajr, athan_dhuhr, athan_asr, athan_maghrib, athan_isha, athan_suhoor, athan_is_ramadan, athan_is_eid) — readable by any app or flow"
    },
    "1.4.30": {
      "en": "Fix Prayer Schedule device pairing — now appears in Add Device"
    },
    "1.4.31": {
      "en": "Fix Prayer Schedule device not appearing in pairing list"
    }
  },
  "flow": {
    "triggers": [
      {
        "id": "eid_morning",
        "title": {
          "en": "Eid Morning Alarm",
          "ar": "تنبيه صباح العيد"
        }
      },
      {
        "id": "prayer_started",
        "title": {
          "en": "A prayer starts",
          "ar": "حان وقت الصلاة"
        },
        "titleFormatted": {
          "en": "Prayer starts: [[prayer]]",
          "ar": "حان وقت: [[prayer]]"
        },
        "args": [
          {
            "name": "prayer",
            "type": "dropdown",
            "values": [
              {
                "id": "Fajr",
                "label": {
                  "en": "Fajr",
                  "ar": "الفجر"
                }
              },
              {
                "id": "Dhuhr",
                "label": {
                  "en": "Dhuhr",
                  "ar": "الظهر"
                }
              },
              {
                "id": "Asr",
                "label": {
                  "en": "Asr",
                  "ar": "العصر"
                }
              },
              {
                "id": "Maghrib",
                "label": {
                  "en": "Maghrib",
                  "ar": "المغرب"
                }
              },
              {
                "id": "Isha",
                "label": {
                  "en": "Isha",
                  "ar": "العشاء"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "suhoor_alarm",
        "title": {
          "en": "Suhoor Alarm (Ramadan Only)",
          "ar": "تنبيه السحور (رمضان فقط)"
        }
      }
    ]
  },
  "drivers": [
    {
      "id": "prayer_schedule",
      "name": {
        "en": "Prayer Schedule",
        "ar": "جدول الصلوات"
      },
      "class": "sensor",
      "capabilities": [
        "is_ramadan",
        "prayer_time.suhoor",
        "prayer_time.fajr",
        "prayer_time.dhuhr",
        "prayer_time.asr",
        "prayer_time.maghrib",
        "prayer_time.isha"
      ],
      "capabilitiesOptions": {
        "is_ramadan": {
          "preventInsights": true
        },
        "prayer_time.suhoor": {
          "title": {
            "en": "Suhoor",
            "ar": "السحور"
          },
          "preventInsights": true
        },
        "prayer_time.fajr": {
          "title": {
            "en": "Fajr",
            "ar": "الفجر"
          },
          "preventInsights": true
        },
        "prayer_time.dhuhr": {
          "title": {
            "en": "Dhuhr",
            "ar": "الظهر"
          },
          "preventInsights": true
        },
        "prayer_time.asr": {
          "title": {
            "en": "Asr",
            "ar": "العصر"
          },
          "preventInsights": true
        },
        "prayer_time.maghrib": {
          "title": {
            "en": "Maghrib",
            "ar": "المغرب"
          },
          "preventInsights": true
        },
        "prayer_time.isha": {
          "title": {
            "en": "Isha",
            "ar": "العشاء"
          },
          "preventInsights": true
        }
      },
      "images": {
        "small": "/drivers/prayer_schedule/assets/images/small.png",
        "large": "/drivers/prayer_schedule/assets/images/large.png"
      }
    }
  ],
  "capabilities": {
    "is_ramadan": {
      "type": "boolean",
      "title": {
        "en": "Ramadan",
        "ar": "رمضان"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "prayer_time": {
      "type": "number",
      "title": {
        "en": "Prayer Time",
        "ar": "وقت الصلاة"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "units": {
        "en": "min"
      },
      "min": 0,
      "max": 1439,
      "decimals": 0
    }
  }
}